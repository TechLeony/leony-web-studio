# Existing Leony Supabase
SUPABASE_PROJECT_ID=
SUPABASE_KEY=
SUPABASE_URL=
VITE_SUPABASE_ID=
VITE_SUPABASE_KEY=
VITE_SUPABASE_URL=

# StoryOfUs External Supabase
VITE_STORYOFUS_SUPABASE_URL=
VITE_STORYOFUS_SUPABASE_ANON_KEY=
STORYOFUS_SUPABASE_SERVICE_ROLE_KEY=

# StoryOfUs Email Worker
# Server-side secret used to authenticate protected worker invocations. Do not prefix with VITE_.
STORYOFUS_EMAIL_WORKER_SECRET=

# StoryOfUs Shopier Product Checkout
# Server-side Shopier Personal Access Token. Do not prefix with VITE_.
SHOPIER_ACCESS_TOKEN=
SHOPIER_PAYMENT_AMOUNT_TRY=199
SHOPIER_PAYMENT_CURRENCY=TRY

# StoryOfUs Shopier Webhook
# Server-only signing token returned when the webhook subscription is created.
# Do not prefix with VITE_.
SHOPIER_WEBHOOK_SECRET=

# StoryOfUs Admin Analytics
# Optional server-side estimated Shopier fee settings used by the admin dashboard.
# If omitted, commission and net revenue are shown as unavailable.
# Values are decimal rates, for example 0.0399 for 3.99% and 0.20 for 20% VAT.
STORYOFUS_SHOPIER_COMMISSION_RATE=
STORYOFUS_SHOPIER_COMMISSION_VAT_RATE=

# StoryOfUs Checkout Rate Limit
# Separate server-only secret used to HMAC checkout rate-limit identifiers.
# Must be at least 32 characters. Do not prefix with VITE_.
STORYOFUS_CHECKOUT_RATE_LIMIT_SECRET=

# StoryOfUs Final Site Passcode Rate Limit
# Server-only HMAC secret for final-site passcode attempt buckets.
# Use a strong random value of at least 32 characters. Do not prefix with VITE_.
# If omitted, the implementation falls back to STORYOFUS_CHECKOUT_RATE_LIMIT_SECRET.
# A dedicated value is recommended for secret isolation.
STORYOFUS_PASSCODE_RATE_LIMIT_SECRET=
